# لوحة التحكم
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=your-random-secret-key-min-32-chars
# طوارئ: true = تجاهل كلمة المرور المحفوظة واستخدم ADMIN_PASSWORD فقط
ADMIN_USE_ENV_PASSWORD=false

# Supabase (التخزين الرئيسي — موصى به)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=uploads

# تخزين Vercel Blob (احتياطي — اختياري)
BLOB_READ_WRITE_TOKEN=

# إرسال إيميلات الحجز (اختياري)
RESEND_API_KEY=
RESEND_FROM=مكتب صالح العمري <noreply@ssa-law.com>
